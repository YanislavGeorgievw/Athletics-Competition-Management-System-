void manageFile(Athlete athletes[], int &count, int &count_sprint, int &count_relay, int &count_shot, int &count_p_vault, int &count_t_jump)
{
    int choice;
    do
    {
        displayManageFileMenu();
        cin >> choice;
        switch (choice)
        {
        case 1:
            saveDataB(athletes, count, count_sprint, count_relay, count_shot, count_p_vault, count_t_jump);
            break;
        case 2:
            loadDataB(athletes, count, count_sprint, count_relay, count_shot, count_p_vault, count_t_jump);
            break;
        case 0:
            cout << "\nReturning to Main Menu.\n";
            break;
        default:
            break;
        }
    } while (choice != 0);
}

