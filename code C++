void saveDataB(Athlete athletes[], int count, int count_sprint, int count_relay, int count_shot, int count_p_vault, int count_t_jump)
{
    if (count == 0)
    {
        cout << "\nNo athletes has been added.\n";
        return;
    }
    ofstream saveFile("dataB.bin", ios_base::binary);
    if (!saveFile)
    {
        cout << "\nError appeared while opening the file!\n";
        saveFile.close();
        return;
    }
    int size_name;
    const char* str_name;
    int size_discipline;
    const char* str_discipline;
    int size_country;
    const char* str_country;
    saveFile.write((char*)&count, sizeof(int));
    for (int i = 0;i < count;i++)
    {
        size_name = athletes[i].name.size();
        str_name = athletes[i].name.c_str();
        size_discipline = athletes[i].discipline.size();
        str_discipline = athletes[i].discipline.c_str();
        size_country = athletes[i].country.size();
        str_country = athletes[i].country.c_str();
        saveFile.write((char*)&athletes[i].athleteNumber, sizeof(int));
        saveFile.write((char*)&size_name, sizeof(int));
        saveFile.write(str_name, size_name + 1);
        saveFile.write((char*)&athletes[i].age, sizeof(int));
        saveFile.write((char*)&size_discipline, sizeof(int));
        saveFile.write(str_discipline, size_discipline + 1);
        saveFile.write((char*)&athletes[i].bestCareerResult, sizeof(float));
        saveFile.write((char*)&athletes[i].bestResultThisYear, sizeof(float));
        saveFile.write((char*)&athletes[i].participationCount, sizeof(int));
        saveFile.write((char*)&size_country, sizeof(int));
        saveFile.write(str_country, size_country + 1);
        saveFile.write((char*)&athletes[i].result, sizeof(float));
        saveFile.write((char*)&athletes[i].place, sizeof(int));
    }
    saveFile.write((char*)&count_sprint, sizeof(int));
    saveFile.write((char*)&count_relay, sizeof(int));
    saveFile.write((char*)&count_shot, sizeof(int));
    saveFile.write((char*)&count_p_vault, sizeof(int));
    saveFile.write((char*)&count_t_jump, sizeof(int));
    saveFile.close();
    cout << "\nData succesfully saved.\n";
}

void loadDataB(Athlete athletes[], int &count, int &count_sprint, int &count_relay, int &count_shot, int &count_p_vault, int &count_t_jump)
{
    ifstream loadFile("dataB.bin", ios_base::binary | ios_base::ate);
    if (!loadFile)
    {
        cout << "\nError appeared while opening the file!\n";
        loadFile.close();
        return;
    }    
    streampos fileSize = loadFile.tellg();
    if (fileSize == 0)
    {
        cout << "\nNo data has been saved in the file.\n";
        loadFile.close();
        return;
    }
    loadFile.seekg(0, ios_base::beg);
    loadFile.read((char*)&count, sizeof(int));
    int size_name, size_discipline, size_country;
    char* str_name, * str_discipline, * str_country;
    for (int i = 0;i < count;i++)
    {
        loadFile.read((char*)&athletes[i].athleteNumber, sizeof(int));
        loadFile.read((char*)&size_name, sizeof(int));
        str_name = (char*)calloc(size_name + 1, 1);
        loadFile.read(str_name, size_name + 1);
        athletes[i].name = str_name;
        loadFile.read((char*)&athletes[i].age, sizeof(int));
        loadFile.read((char*)&size_discipline, sizeof(int));
        str_discipline = (char*)calloc(size_discipline + 1, 1);
        loadFile.read(str_discipline, size_discipline + 1);
        athletes[i].discipline = str_discipline;
        loadFile.read((char*)&athletes[i].bestCareerResult, sizeof(float));
        loadFile.read((char*)&athletes[i].bestResultThisYear, sizeof(float));
        loadFile.read((char*)&athletes[i].participationCount, sizeof(int));
        loadFile.read((char*)&size_country, sizeof(int));
        str_country = (char*)calloc(size_country + 1, 1);
        loadFile.read(str_country, size_country + 1);
        athletes[i].country = str_country;
        loadFile.read((char*)&athletes[i].result, sizeof(float));
        loadFile.read((char*)&athletes[i].place, sizeof(int));
    }
    loadFile.read((char*)&count_sprint, sizeof(int));
    loadFile.read((char*)&count_relay, sizeof(int));
    loadFile.read((char*)&count_shot, sizeof(int));
    loadFile.read((char*)&count_p_vault, sizeof(int));
    loadFile.read((char*)&count_t_jump, sizeof(int));
    loadFile.close();
    cout << "\nData succesfully loaded\n";
}
