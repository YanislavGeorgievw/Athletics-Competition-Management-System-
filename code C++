void sortAthletesBySport(Athlete a[], int b)
{
    if (b == 0)
    {
        cout << "\nNo athletes has been added.\n";
        return;
    }
    Athlete temp;
    for (int i = 0;i < b;i++)
        for (int j = 0;j + 1 < b - i; j++)
            if (a[j].discipline > a[j + 1].discipline)
            {
                temp = a[j];
                a[j] = a[j + 1];
                a[j + 1] = temp;
            }
            else if (a[j].discipline == a[j + 1].discipline && a[j].name > a[j + 1].name)
            {
                temp = a[j];
                a[j] = a[j + 1];
                a[j + 1] = temp;
            }
    cout << "\nAthlete(s) has been successfully sorted.\n";
}

